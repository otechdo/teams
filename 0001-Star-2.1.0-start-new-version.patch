From e1063df1b785c41a30ff5f1d1ef0a6b758ff7efe Mon Sep 17 00:00:00 2001
From: Willy Micieli <otechdo@otechdo.com>
Date: Thu, 18 Jul 2024 07:37:39 +0200
Subject: [PATCH] Star(2.1.0): start new version

---
 Cargo.lock  |  2 +-
 Cargo.toml  |  2 +-
 src/main.rs | 30 +++++++++---------------------
 3 files changed, 11 insertions(+), 23 deletions(-)

diff --git a/Cargo.lock b/Cargo.lock
index f2deefa..6dda97c 100644
--- a/Cargo.lock
+++ b/Cargo.lock
@@ -34,7 +34,7 @@ checksum = "baf1de4339761588bc0619e3cbc0120ee582ebb74b53b4efbf79117bd2da40fd"
 
 [[package]]
 name = "commiter"
-version = "2.0.0"
+version = "2.1.0"
 dependencies = [
  "inquire",
 ]
diff --git a/Cargo.toml b/Cargo.toml
index 697cf2a..a08b5df 100644
--- a/Cargo.toml
+++ b/Cargo.toml
@@ -1,6 +1,6 @@
 [package]
 name = "commiter"
-version = "2.0.0"
+version = "2.1.0"
 edition = "2021"
 license-file = "LICENSE"
 repository = "https://github.com/otechdo/commiter"
diff --git a/src/main.rs b/src/main.rs
index dee7bf4..58d6741 100644
--- a/src/main.rs
+++ b/src/main.rs
@@ -6,7 +6,7 @@ use std::process::Command;
 
 use inquire::{Confirm, Select, Text};
 
-const TYPES: [&str; 69] = [
+pub const TYPES: [&str; 69] = [
     "Star",
     "Comet",
     "Nebula",
@@ -77,6 +77,7 @@ const TYPES: [&str; 69] = [
     "Expansion",
     "Big Crunch",
 ];
+
 const HELP: [&str; 69] = [
     "Star: New feature or enhancement",
     "Comet: Bug fix or error resolution",
@@ -350,16 +351,9 @@ fn publish() {
     }
 }
 
-fn quit() -> bool {
-    Confirm::new("Quit commiter?")
-        .with_default(false)
-        .prompt()
-        .unwrap()
-}
-
 fn send() {
     if Confirm::new("Send to remotes?")
-        .with_default(false)
+        .with_default(true)
         .prompt()
         .unwrap()
         .eq(&true)
@@ -398,18 +392,12 @@ fn main() {
             .unwrap()
             .success());
     }
-    loop {
-        if zuu() {
-            diff();
-            prepare_commit();
-            send();
-            if Path::new("Cargo.toml").exists() {
-                publish();
-            }
-            if quit() {
-                break;
-            }
+    if zuu() {
+        diff();
+        prepare_commit();
+        send();
+        if Path::new("Cargo.toml").exists() {
+            publish();
         }
     }
-    println!("Bye");
 }
-- 
2.45.2

